# Application
APP_NAME="OpsKnowledge Agent Lite"
DEBUG=false

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=opsknowledge
POSTGRES_USER=opsuser
POSTGRES_PASSWORD=opspassword

# ── Provider selection ────────────────────────────────────────────────────────
# "openai" — calls the OpenAI-compatible API; requires a real OPENAI_API_KEY.
# "ollama" — (LLM_PROVIDER only) calls a local Ollama server; no OpenAI account
#            needed. For private / on-premise deployment. See OLLAMA_* below.
# "mock"   — deterministic local provider; NO API key needed; safe for CI / local dev.
#            MockEmbeddingProvider returns fixed-dim unit vectors (no network call).
#            MockLLMProvider returns a deterministic answer from retrieved context.
#            Switch to mock mode to verify the full pipeline without any external account.
# Local interview/demo mode defaults to Ollama for the LLM and mock embeddings
# for deterministic local vector search without OpenAI.
EMBEDDING_PROVIDER=mock
LLM_PROVIDER=ollama
MOCK_EMBEDDING_DIM=384
EMBEDDING_DIMENSIONS=384

# ── OpenAI-compatible LLM ─────────────────────────────────────────────────────
# Only required when EMBEDDING_PROVIDER=openai or LLM_PROVIDER=openai.
# These values are ignored in mock mode. Leave OPENAI_API_KEY empty in mock mode.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Ollama (local LLM provider for private / on-premise deployment) ───────────
# Used only when LLM_PROVIDER=ollama. The app calls the Ollama HTTP API
# (/api/chat) directly — no OpenAI account required. With Docker Compose, pull
# the model into the ollama_data volume using:
#   docker compose exec ollama ollama pull qwen2.5:7b-instruct
# Note: embeddings still use EMBEDDING_PROVIDER (openai/mock); Ollama covers the LLM only.
OLLAMA_BASE_URL=http://localhost:11434
# Docker Compose overrides OLLAMA_BASE_URL for the backend container.
# The default points to the bundled ollama service; use host.docker.internal
# only when you intentionally run Ollama on the host instead of compose.
DOCKER_OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
