# Application
APP_NAME="OpsKnowledge Agent Lite"
DEBUG=false

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=opsknowledge
POSTGRES_USER=opsuser
POSTGRES_PASSWORD=opspassword

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=opsknowledge_docs

# LLM Provider (OpenAI-compatible)
# OPENAI_API_KEY is REQUIRED for document embedding and semantic search.
# Embedding/search will fail with a clear error if this is left as the placeholder.
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
